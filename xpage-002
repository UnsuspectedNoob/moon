### 5. `src/main.c` (Manual Test Harness)

We replace the previous Scanner test with a VM test.
We will manually program the VM to calculate `-((1.2 + 3.4) / 5.6)`.

**`src/main.c`**

```c
#include <stdio.h>
#include "common.h"
#include "chunk.h"
#include "debug.h"
#include "vm.h"

int main(int argc, char* argv[]) {
  initVM();

  Chunk chunk;
  initChunk(&chunk);

  // Manually writing bytecode for: -((1.2 + 3.4) / 5.6)
  
  // 1. Load 1.2
  int constant = addConstant(&chunk, 1.2);
  writeChunk(&chunk, OP_CONSTANT, 123);
  writeChunk(&chunk, constant, 123);

  // 2. Load 3.4
  constant = addConstant(&chunk, 3.4);
  writeChunk(&chunk, OP_CONSTANT, 123);
  writeChunk(&chunk, constant, 123);

  // 3. Add them (Stack: 4.6)
  writeChunk(&chunk, OP_ADD, 123);

  // 4. Load 5.6
  constant = addConstant(&chunk, 5.6);
  writeChunk(&chunk, OP_CONSTANT, 123);
  writeChunk(&chunk, constant, 123);

  // 5. Divide (4.6 / 5.6)
  writeChunk(&chunk, OP_DIVIDE, 123);

  // 6. Negate
  writeChunk(&chunk, OP_NEGATE, 123);

  // 7. Return (Print result)
  writeChunk(&chunk, OP_RETURN, 123);

  // Verify by disassembling first
  disassembleChunk(&chunk, "test chunk");
  
  // Run it
  printf("\n== EXECUTION ==\n");
  interpret(&chunk);

  freeChunk(&chunk);
  freeVM();
  return 0;
}

```

