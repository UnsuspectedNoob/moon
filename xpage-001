#### 2. `src/scanner.h`

This is the contract between the Scanner and the Parser.

**Critical Design Decisions here:**

* **`TOKEN_POSSESSIVE`**: We treat `'s` as a single token. This simplifies parsing `p's name` significantly.
* **`TOKEN_EOF`**: Essential for the parser to know when to stop.
* **`TOKEN_ERROR`**: If the scanner finds a bad character, it returns a special error token so the parser can handle it gracefully (or panic).

```c
#ifndef MOON_SCANNER_H
#define MOON_SCANNER_H

typedef enum {
  // Single-character tokens
  TOKEN_LEFT_PAREN, TOKEN_RIGHT_PAREN,
  TOKEN_LEFT_BRACKET, TOKEN_RIGHT_BRACKET,
  TOKEN_COMMA, TOKEN_DOT, TOKEN_MINUS, TOKEN_PLUS,
  TOKEN_SLASH, TOKEN_STAR,

  // One or two character tokens
  TOKEN_BANG, TOKEN_BANG_EQUAL,
  TOKEN_EQUAL, TOKEN_EQUAL_EQUAL,
  TOKEN_GREATER, TOKEN_GREATER_EQUAL,
  TOKEN_LESS, TOKEN_LESS_EQUAL,
  TOKEN_POSSESSIVE, // 's

  // Literals
  TOKEN_IDENTIFIER, TOKEN_STRING, TOKEN_NUMBER,

  // Keywords
  TOKEN_ADD, TOKEN_AND, TOKEN_ASK, TOKEN_BE, 
  TOKEN_BREAK, TOKEN_ELSE, TOKEN_END, TOKEN_FALSE, 
  TOKEN_FOR, TOKEN_FROM, TOKEN_GIVE, TOKEN_IF, 
  TOKEN_IN, TOKEN_IS, TOKEN_LET, TOKEN_NULL, 
  TOKEN_OR, TOKEN_QUIT, TOKEN_RETURN, TOKEN_SET, 
  TOKEN_SHOW, TOKEN_SKIP, TOKEN_TO, TOKEN_TRUE, 
  TOKEN_TYPE, TOKEN_UNLESS, TOKEN_UNTIL, TOKEN_WHILE,

  TOKEN_ERROR, TOKEN_EOF
} TokenType;

typedef struct {
  TokenType type;
  const char* start; // Pointer to the start of the token in source
  int length;        // Length of the token
  int line;          // Line number for error reporting
} Token;

// Initialize the scanner with the source code string
void initScanner(const char* source);

// Scan the next token from the source
Token scanToken();

#endif

```

