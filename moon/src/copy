  }
  case OBJ_TYPE_BLUEPRINT:
    printf("<type %s>", AS_TYPE(value)->name->chars);
    break;
  case OBJ_INSTANCE:
    printf("<%s instance>", AS_INSTANCE(value)->type->name->chars);
    break;
  case OBJ_MULTI_FUNCTION:
