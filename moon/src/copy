    InterpolationPayload interpolation;
    SingleExprPayload singleExpr;
    SetPayload set;
    IfPayload ifStmt;
    WhilePayload whileStmt;
    ForPayload forStmt;
    BlockPayload block;
    LetPayload let;
    FunctionPayload function;
    RangePayload range;
    ListPayload list;
    DictPayload dictExpr;
    SubscriptPayload subscript;
  } as;
};
